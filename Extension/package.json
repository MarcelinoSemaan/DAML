{
  "name": "daml-dashboard",
  "displayName": "DAML Protection",
  "description": "AI-powered malware detection dashboard using EMBER-LSTM engine",
  "version": "0.0.1",
  "publisher": "Marcelino-Ahmad",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other",
    "Machine Learning",
    "Visualization"
  ],
  "keywords": [
    "malware",
    "security",
    "pe",
    "detection",
    "ai"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "daml-explorer",
          "title": "DAML Protection",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "daml-explorer": [
        {
          "type": "webview",
          "id": "daml.dashboardView",
          "name": "Dashboard"
        }
      ]
    },
    "commands": [
      {
        "command": "daml.showMenu",
        "title": "DAML: Show Quick Pick Menu"
      },
      {
        "command": "daml.showDashboard",
        "title": "DAML: Open Dashboard"
      },
      {
        "command": "daml.scanWorkspace",
        "title": "DAML: Scan Workspace"
      },
      {
        "command": "daml.scanActiveFile",
        "title": "DAML: Scan Active File"
      },
      {
        "command": "daml.scanPeFile",
        "title": "DAML: Scan PE File..."
      },
      {
        "command": "daml.scanJsonClipboard",
        "title": "DAML: Scan JSON from Clipboard"
      },
      {
        "command": "daml.toggleStatusView",
        "title": "DAML: Turn Protection On/Off"
      },
      {
        "command": "daml.selectCompiler",
        "title": "DAML: Select Compiler",
        "category": "DAML"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "ts-loader": "9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1"
  }
}